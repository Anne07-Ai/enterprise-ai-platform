# Local infrastructure credentials.
# Copy to .env and edit before `make up`. Defaults are intentionally obvious — never deploy these.

# --- Postgres -------------------------------------------------------------
POSTGRES_USER=eaip
POSTGRES_PASSWORD=changeme_local_only
POSTGRES_DB=eaip

# --- Redis ----------------------------------------------------------------
REDIS_PASSWORD=changeme_local_only

# --- MinIO (S3-compatible object storage) ---------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_local_only

# --- Grafana --------------------------------------------------------------
GRAFANA_ADMIN_PASSWORD=admin

# --- Application keys (Phase 2+) ------------------------------------------
# Left blank for Phase 1 — the infra plane does not need them. Populate before
# the API service is added in Phase 2.
ANTHROPIC_API_KEY=
JWT_SECRET=
