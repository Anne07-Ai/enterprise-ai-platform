# Local infrastructure + API credentials.
# Copy to .env and edit before `make up`. Defaults are intentionally obvious — never deploy these.

# --- Infra credentials (Phase 1) -----------------------------------------
POSTGRES_USER=eaip
POSTGRES_PASSWORD=changeme_local_only
POSTGRES_DB=eaip

REDIS_PASSWORD=changeme_local_only

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_local_only

GRAFANA_ADMIN_PASSWORD=admin

# --- API service (Phase 2) -----------------------------------------------
# All EAIP_* keys are read by Pydantic Settings inside the api container.
# Compose injects in-container DNS overrides for the connection URLs; the
# values below are the host-side equivalents used when running the API
# directly with `uv run uvicorn ...` outside Docker.

EAIP_ENVIRONMENT=local
EAIP_LOG_LEVEL=INFO

EAIP_DATABASE_URL=postgresql+asyncpg://eaip:changeme_local_only@localhost:5432/eaip
EAIP_REDIS_URL=redis://:changeme_local_only@localhost:6379/0
EAIP_KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# JWT signing keys. If unset (or files missing), the API generates an
# ephemeral RSA keypair at startup with a loud warning. Production must mount
# real key files and set both paths.
EAIP_AUTH_JWT_PRIVATE_KEY_PATH=
EAIP_AUTH_JWT_PUBLIC_KEY_PATH=
EAIP_AUTH_JWT_ALGORITHM=RS256
EAIP_AUTH_ACCESS_TOKEN_TTL_SECONDS=900
EAIP_AUTH_REFRESH_TOKEN_TTL_SECONDS=604800

EAIP_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Set to 1 to allow the demo seed script to run.
EAIP_SEED_DEMO=0

# --- Phase 3+ keys (left blank) ------------------------------------------
ANTHROPIC_API_KEY=

# --- LLM / Embedding providers (Phase 3) ---------------------------------
# OpenAI for embeddings (text-embedding-3-small). Required for ingestion +
# search workers. Anthropic for chat (Phase 6+).
EAIP_OPENAI_API_KEY=
EAIP_OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EAIP_ANTHROPIC_API_KEY=
